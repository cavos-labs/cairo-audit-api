{
  "openapi": "3.1.0",
  "info": {
    "title": "Cairo Security & Audit API",
    "description": "AI-powered security audit and gas optimization for Cairo 1.0 smart contracts.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://cairo-audit-api-production.up.railway.app",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v1/audit": {
      "post": {
        "summary": "Audit Cairo code",
        "description": "Performs a security audit on the provided Cairo 1.0 source code.",
        "operationId": "auditCairoCode",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string",
                    "minLength": 10,
                    "description": "Cairo 1.0 source code"
                  }
                },
                "required": ["code"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audit results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "vulnerabilities": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": { "type": "string" },
                          "severity": { "type": "string" },
                          "detail": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "402": {
            "description": "Payment Required (x402 Protocol)",
            "content": {
              "application/json": {
                "example": {
                  "x402Version": 2,
                  "accepted": {
                    "scheme": "exact",
                    "network": "eip155:8453",
                    "amount": "50000",
                    "asset": "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913",
                    "payTo": "0x2C175a3d31B21CFcB8C1091D1775ae59bdDca782"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "x402": {
        "type": "apiKey",
        "name": "PAYMENT-SIGNATURE",
        "in": "header",
        "description": "x402 protocol payment signature"
      }
    }
  }
}
